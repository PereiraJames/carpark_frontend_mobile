# Copy this file to `.env` and fill in real values.
# Both vars are inlined into the JS bundle at build time (EXPO_PUBLIC_ prefix),
# so don't put secrets here that must stay server-side.

# Base URL of the Flask backend (carpark_app). Update if the server's LAN IP changes.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.39:5000

# Google Maps JavaScript/Geocoding API key (same one used by templates/map.html).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCI1RypXWz8AEIjjTV4g3ckiwH-Kw0hBVY
